{
  "name": "vessel-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "AI-enabled enterprise Vessel Management System.",
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run db:generate && npm run build --workspaces --if-present",
    "build:web": "npm --workspace @vms/web run build",
    "start": "npm --workspace @vms/api run start",
    "start:api": "npm --workspace @vms/api run start",
    "dev": "npm --workspace @vms/web run dev",
    "dev:api": "npm --workspace @vms/api run dev",
    "dev:web": "npm --workspace @vms/web run dev",
    "lint": "eslint apps packages --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && PLAYWRIGHT_BROWSERS_PATH=.ms-playwright playwright test",
    "verify": "npm run format:check && npm run lint && npm run test && npm run build",
    "db:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "db:seed:demo": "tsx packages/database/prisma/seed-peel-ports-demo.ts",
    "db:studio": "prisma studio --schema packages/database/prisma/schema.prisma",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@nestjs/testing": "^11.1.27",
    "@next/eslint-plugin-next": "^15.3.4",
    "@playwright/test": "^1.53.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.6.2",
    "prisma": "^6.10.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^6.10.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "overrides": {
    "js-yaml": "^4.3.0",
    "multer": "^2.2.0",
    "postcss": "^8.5.10"
  }
}
